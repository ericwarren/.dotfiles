{
  "alwaysThinkingEnabled": true,
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/home/eric/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)",
      "Read(**/credentials.yaml)",
      "Read(**/*secret*)",
      "Read(**/*password*)",
      "Read(**/*token*)",
      "Read(**/*apikey*)",
      "Read(**/*api-key*)",
      "Read(**/.ssh/**)",
      "Read(**/.gnupg/**)",
      "Read(**/.password-store/**)",
      "Read(**/id_rsa*)",
      "Read(**/id_ed25519*)",
      "Read(**/id_ecdsa*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.pfx)",
      "Read(**/*.p12)",
      "Read(**/.aws/credentials)",
      "Read(**/.kube/config)",
      "Read(**/vault/**)"
    ]
  },
  "statusLine": {
    "command": "bash ~/.claude/statusline.sh",
    "type": "command"
  },
  "theme": "dark",
  "tui": "fullscreen"
}
