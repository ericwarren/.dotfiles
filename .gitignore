nvim/.config/nvim/undodir/*
nvim/.config/nvim/plugged/*

# Runtime and cache directories
**/.local/share/
**/.local/state/

# Source code directories (only dotfiles, not entire source repos)
wezterm/target/
wezterm/.git/
wezterm/Cargo.lock

# Build artifacts and compiled code
**/target/
**/.cargo/
**/.git/

# Temporary and backup files
**/*~
**/*.bak
**/.*swp
**/.*swo
emacs/.local/

# systemd enable-state (generated by 'systemctl enable' — machine-local symlinks
# to absolute paths; the actual unit files like emacs.service stay tracked)
**/*.target.wants/

# Claude Code — never commit secrets, machine state, or project-local settings
/.claude/settings.local.json
claude/.claude/settings.local.json
claude/.claude/.credentials.json
claude/.claude/history.jsonl
claude/.claude/projects/
claude/.claude/todos/
claude/.claude/shell-snapshots/

# Pi coding agent — never commit credentials, session state, or trust decisions
pi/.pi/agent/auth.json
pi/.pi/agent/trust.json
pi/.pi/agent/settings.local.json
pi/.pi/agent/sessions/
pi/.pi/agent/npm/
